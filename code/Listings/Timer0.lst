   1          #include <STC12C5A60S2.H>
   2          
   3          void Timer0_Init(void)          //1毫秒@11.0592MHz
   4          {
   5   1              TMOD &= 0xF0;                   //设置定时器模式
   6   1              TMOD |= 0x01;                   //设置定时器模式
   7   1              TL0 = 0x66;                             //设置定时初始值
   8   1              TH0 = 0xFC;                             //设置定时初始值
   9   1              TF0 = 0;                                //清除TF0标志
  10   1              TR0 = 1;                                //定时器0开始计时
  11   1              ET0 = 1;                                //使能定时器0中断
  12   1              EA=1;
  13   1      }
  14          void Timer0_close(void)
  15          {
  16   1              TR0 = 0;
  17   1              ET0 = 0;
  18   1              EA=0;
  19   1      }
